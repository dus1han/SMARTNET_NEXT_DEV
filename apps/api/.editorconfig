# The scaffolded legacy entities and DbContext mirror a schema we do not control
# (varchar money, no primary keys, MySQL-ish naming). Analysing them is noise —
# we are not going to rename `UserPermission` in a table we did not design.
#
# Everything we write by hand is still fully analysed, including the banned-symbol
# rules: no double-typed money, no raw SQL, no DateTime.Now.

[Smartnet.Infrastructure/Entities/**.cs]
dotnet_analyzer_diagnostic.severity = none
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA2227.severity = none
dotnet_diagnostic.CA1002.severity = none

[Smartnet.Infrastructure/Persistence/SmartnetLegacyDbContext.cs]
dotnet_analyzer_diagnostic.severity = none

# CA1711 reserves the suffix "Permission" for the old Code Access Security types, which have
# nothing to do with this codebase. `RolePermission` and `UserPermissionOverride` are the correct
# names for what they are, and renaming them to satisfy a rule about CAS would make the domain
# harder to read, not safer. The suffix is allowed; the rest of CA1711 still applies.
[*.cs]
dotnet_code_quality.CA1711.allowed_suffixes = Permission
