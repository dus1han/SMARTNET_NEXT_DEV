# build
bin/
obj/
node_modules/
.next/
dist/

# env / secrets
.env
.env.*
!.env.example
appsettings.*.local.json

# os
Thumbs.db
.DS_Store

# data dumps - contain customer data
*.sql
*.dump
data/

# ...but infra/sql holds operational scripts, not data. They contain no customer
# rows and they have to be version-controlled, because they are steps somebody
# runs against live at cutover. The blanket *.sql above had been silently
# swallowing them: audit-log-grants.sql sat on one developer's disk and in no
# clone, which is the likeliest reason it was never run anywhere.
!infra/sql/
!infra/sql/*.sql

# build artifacts
bin/
obj/
.next/
node_modules/

# Uploaded documents (Phase 7, slice 4). The local development store — the real one is a mounted
# volume on the server. These are the business's own files (BRC, TIN and VAT certificates, signed
# agreements); they are not source, and a stray `git add -A` must never put them in the history.
App_Data/
