# ---- database: the DEV copy on the host. NEVER smartnet_invsys ----
ConnectionStrings__Smartnet=Server=185.73.8.1;Database=smartnet_invsys_dev;User=smartnet_invsys_next;Password=CHANGE_ME;

# ---- auth ----
# The JWT signing key. Anyone holding it can mint a token for any user, so it is generated per
# environment and never committed. The API refuses to start without one — there is deliberately
# no default, because a default signing key is the same mistake as the legacy app's hardcoded
# database password, only worse.
#
#   openssl rand -base64 48
Jwt__SigningKey=CHANGE_ME
Jwt__Issuer=smartnet
Jwt__Audience=smartnet
Jwt__AccessTokenMinutes=30

# ---- api ----
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5080
Cors__WebOrigin=http://localhost:3000

# ---- web ----
NEXT_PUBLIC_API_URL=http://localhost:5080
