root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
dotnet_diagnostic.RS0030.severity = error   # banned symbols (double money, raw SQL, DateTime.Now)
csharp_style_namespace_declarations = file_scoped:warning

[*.{ts,tsx,js,jsx,json,yml,yaml,css}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
